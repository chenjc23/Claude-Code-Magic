# 启用 custom provider                        
CLAUDE_CODE_USE_CUSTOM=true

# LiteLLM 地址
ANTHROPIC_BASE_URL=http://localhost:4000
# ANTHROPIC_BASE_URL=https://openrouter.ai/api
# ANTHROPIC_BASE_URL=https://api.deepseek.com

# API 认证（二选一）
# ANTHROPIC_API_KEY=sk-
ANTHROPIC_API_KEY=sk-
# 禁用官方token认证
CLAUDE_CODE_DISABLE_OAUTH=true
#   ANTHROPIC_AUTH_TOKEN=

# 不同外部模型有上午文token限制
CLAUDE_CODE_MAX_OUTPUT_TOKENS=8192

# /model 里显示的内容 + 实际发给 API 的模型名
# ANTHROPIC_DEFAULT_SONNET_MODEL=z-ai/glm-4.7
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-chat
# ANTHROPIC_DEFAULT_SONNET_MODEL_NAME=GLM-4
# ANTHROPIC_DEFAULT_SONNET_MODEL_DESCRIPTION=智谱GLM-4·日常任务

ANTHROPIC_DEFAULT_OPUS_MODEL=z-ai/glm-5
# ANTHROPIC_DEFAULT_OPUS_MODEL_NAME=GPT-4o
# ANTHROPIC_DEFAULT_OPUS_MODEL_DESCRIPTION=OpenAI GPT-4o·复杂任务

ANTHROPIC_DEFAULT_HAIKU_MODEL=z-ai/glm-4.6
# ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME=GLM-4-Flash
# ANTHROPIC_DEFAULT_HAIKU_MODEL_DESCRIPTION=GLM-4-Flash·快速响应

# 超时（毫秒）
API_TIMEOUT_MS=3000000

# 禁用遥测和非必要网络请求
DISABLE_TELEMETRY=1
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1